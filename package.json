{
  "name": "@superinstance/agent-core",
  "version": "1.0.0",
  "description": "Minimal SDK combining EscalationEngine (40x cost reduction), HierarchicalMemory (4-tier cognitive memory), and TripartiteConsensus (reliable AI decisions)",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "bun test",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agents",
    "llm",
    "memory",
    "consensus",
    "cost-optimization",
    "cognitive-architecture"
  ],
  "author": "SuperInstance",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SuperInstance/SuperInstance-SDK1.git"
  },
  "bugs": {
    "url": "https://github.com/SuperInstance/SuperInstance-SDK1/issues"
  },
  "homepage": "https://github.com/SuperInstance/SuperInstance-SDK1#readme",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
